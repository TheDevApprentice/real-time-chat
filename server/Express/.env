#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY="02b71fa3c2fd1d8dd37588bf4da827248a1807c87187ff6ad24370e59da238a3c7"

# .env
# server/.env
NODE_ENV=production
DEBUG=true
PORT=3080
FRONTEND_URL=http://localhost
# Trust proxy (e.g. when behind a reverse proxy)
TRUST_PROXY="true"
# Bcrypt cost
BCRYPT_COST="12"
# Redis configuration
REDIS_URL=redis://:changeme@redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USER=changeme
REDIS_PASSWORD=changeme
REDIS_TLS=false
# S3/MinIO configuration
# S3_ENDPOINT=http://localhost:9000
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminadmin123
S3_BUCKET=chat-bucket
S3_USE_PATH_STYLE="true"
# Base URL for public access from host (used to form public links)
# This is what browsers will use via Traefik
S3_PUBLIC_URL_BASE=http://localhost/minio/chat-bucket
# Database configuration
DATABASE_DRIVER=mariadb
# SQLite configuration
# SQLITE_FILE=/data/chat.sqlite
# MySQL configuration
# MYSQL_HOST=mysql
# MYSQL_PORT=3306
# MYSQL_DB=chat
# MYSQL_USER=chat
# MYSQL_PASSWORD=chat
# MYSQL_SSL=false
# MariaDB configuration
MARIADB_HOST=proxysql
MARIADB_PORT=6033
MARIADB_DB=chat
MARIADB_USER=chat
MARIADB_PASSWORD=chat
MARIADB_SSL=false
# MariaDB backup configuration
MARIADB_HOST_BACKUP=mariadb_backup
MARIADB_PORT_BACKUP=3306
MARIADB_DB_BACKUP=chat_backup
MARIADB_USER_BACKUP=chat_backup
MARIADB_PASSWORD_BACKUP=chat_backup
MARIADB_SSL_BACKUP=false
WEBRTC_STUN=stun:stun.l.google.com:19302
# Point to the local TURN (coturn) service below; replace with public DNS when deployed
WEBRTC_TURN_URLS=turn:turn:3478
WEBRTC_TURN_USERNAME=devuser
WEBRTC_TURN_CREDENTIAL=devpass
CALL_RING_TIMEOUT=20