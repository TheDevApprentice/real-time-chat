[mysqld]
# Configuration de base
server-id=3
bind-address=0.0.0.0
skip-name-resolve=1

# Configuration Galera Cluster - NODE 3 (JOIN)
wsrep_on=ON
wsrep_cluster_name="chat_cluster"
wsrep_cluster_address="gcomm://mariadb_galera1:4567"  # Pointe vers galera1 seulement
wsrep_node_address="mariadb_galera3"
wsrep_provider=/usr/lib/galera/libgalera_smm.so

# Configuration SST (State Snapshot Transfer)
wsrep_sst_method=mariabackup
wsrep_sst_auth="sst_user:sst_password"

# Configuration de réplication
wsrep_slave_threads=4
wsrep_log_conflicts=ON
wsrep_retry_autocommit=3

# Configuration de performance
wsrep_provider_options="gcache.size=128M;gcache.page_size=128M;gcache.recover=yes"

# Configuration InnoDB pour Galera
default_storage_engine=InnoDB
innodb_buffer_pool_size=256M
innodb_log_file_size=64M
innodb_flush_log_at_trx_commit=0
innodb_flush_method=O_DIRECT
innodb_autoinc_lock_mode=2
innodb_doublewrite=1

# Configuration binlog
binlog_format=ROW
log_bin=mysql-bin
expire_logs_days=3
max_binlog_size=100M

# Configuration générale
query_cache_type=0
query_cache_size=0

# Monitoring et logging
slow_query_log=ON
slow_query_log_file=/var/log/mysql/slow.log
long_query_time=2
log_queries_not_using_indexes=ON

# Timeouts
wait_timeout=28800
interactive_timeout=28800
connect_timeout=30

# Limites de connexions
max_connections=1000
max_connect_errors=10000
max_allowed_packet=16M
